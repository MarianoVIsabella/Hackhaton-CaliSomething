# Alpaca Paper Trading credentials
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key

# LLM provider: openai or groq
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
# GROQ_API_KEY=your_groq_key
LLM_MODEL=gpt-4o-mini
# For Groq you can use, for example:
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.1-8b-instant

# Trading/demo controls
PAPER_TRADING_ENABLED=false
DEMO_TRADE_MODE=false
DEMO_QUANTITY=1
SYMBOLS=AAPL,MSFT,NVDA,TSLA
DEMO_DURATION_MINUTES=5
CYCLE_SLEEP_SECONDS=60
CONFIDENCE_THRESHOLD=0.70
MAX_POSITION_VALUE_PCT=0.10
